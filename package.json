{
  "name": "submerge",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:infra": "docker compose -p submerge-dev -f docker-compose.dev.yml up -d",
    "dev:server": "packages/server/node_modules/.bin/tsx --env-file=config/dev.env --conditions=development --watch packages/server/src/index.ts",
    "dev:web": "pnpm --dir packages/web dev",
    "build": "pnpm -r run build",
    "typecheck": "tsc -b && pnpm -F @submerge/web typecheck",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "test": "pnpm -r run test",
    "verify:static": "./node_modules/.bin/biome ci . && pnpm -F @submerge/web design:tokens:check && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "typescript": "^6.0.3"
  }
}
