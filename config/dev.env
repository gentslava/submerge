# Local-only development defaults. Existing shell variables take precedence, so
# PORT=3100 pnpm dev:server and VITE_PROXY_TARGET=... pnpm dev:web remain available.
HOST=127.0.0.1
MIHOMO_API=http://127.0.0.1:9090
MIHOMO_PROXY=http://127.0.0.1:7890
MIHOMO_SECRET=dev
HAPP_DECODER_URL=http://127.0.0.1:8080
MIHOMO_CONFIG_PATH=.local-run/mihomo/config.yaml
MIHOMO_CONFIG_TARGET=/root/.config/mihomo/config.yaml
HWID_FILE=.local-run/mihomo/hwid.txt
PROXY_ENDPOINT=127.0.0.1:7890
