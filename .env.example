# submerge — deploy configuration.
#
# Copy this file to `.env` (same directory as docker-compose.yml) and fill it in.
# Compose auto-loads `.env`. `.env` is git-ignored; this template is tracked.
#
# For localhost the compose defaults are fine and you can skip `.env` entirely.
# The values below are the MINIMUM to change before putting the panel on the
# internet — without them the panel is fully open.

# --- Authentication (required for internet-facing deploys) --------------------

# Admin password. Auth is DISABLED while this is empty — anyone can use the panel.
# Set a strong, unique value before exposing the panel. Takes effect on restart.
ADMIN_PASSWORD=

# Secure cookie flag. MUST be "true" when served over HTTPS (i.e. behind a TLS
# reverse-proxy), otherwise the browser drops the session cookie. Keep "false"
# only for plain-HTTP localhost. Do NOT leave blank — an empty value fails to boot.
COOKIE_SECURE=true

# --- Networking ---------------------------------------------------------------

# Host address the panel port binds to. Default "127.0.0.1" keeps it on loopback
# so a TLS reverse-proxy (Traefik/Dokploy/Caddy) can front it — the recommended
# setup. Set "0.0.0.0" only to deliberately publish the port directly (no TLS).
SUBMERGE_BIND=127.0.0.1

# --- Internal ------------------------------------------------------------------

# Secret for the mihomo Clash REST API (internal network only, not published).
# Any non-empty string; change it from the default.
MIHOMO_SECRET=poc
